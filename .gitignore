# Udumalpet Business Tour (UBT) - Root .gitignore

# Dependency Directories
**/node_modules/
node_modules/

# Local Environment Variables & Secrets
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
.env
.env.local
.env.development
.env.production
.env.staging

# Frontend Production Builds & Cache
/frontend/dist/
/frontend/build/
/frontend/.vite/
/frontend/.next/
**/.vite/
**/.next/

# Package Manager Cache & Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.yarn/
.pnpm-store/

# IDE / Editor Settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Diagnostic Logs & OS Metadata
logs/
*.log
npm-debug.log*
yarn-debug.log*
.DS_Store
Thumbs.db
desktop.ini

# Temporary files & Testing coverage
**/coverage/
**/.nyc_output/
tmp/
temp/

